# ──────────────────────────────────────────────
# Backend Environment Variables
# ──────────────────────────────────────────────

# App
PROJECT_NAME=AI Healthcare Assistant API
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database
DATABASE_URL=postgresql://healthcare_user:healthcare_pass@localhost:5432/healthcare_agent
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_REFRESH_TOKEN_REMEMBER_ME_DAYS=30

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=2048

# Google Cloud Vision
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# OCR (Optical Character Recognition)
OCR_ENGINE=tesseract
OCR_PRIMARY_PROVIDER=tesseract
OCR_USE_MOCK=false
OCR_FALLBACK_PROVIDER=tesseract
OCR_RETRY_MAX_ATTEMPTS=3
OCR_RETRY_BACKOFF_SECONDS=2.0
OCR_MIN_CONFIDENCE=0.5
OCR_ENABLED=true
OCR_GOOGLE_VISION_TIMEOUT=60
OCR_IMAGE_DPI=300
OCR_PREPROCESS_ENABLE=true
OCR_PREPROCESS_DENOISE=true
OCR_PREPROCESS_DESKEW=true
OCR_PREPROCESS_BINARIZE=true
TESSERACT_CMD=
OCR_LANGUAGE=eng
OCR_TIMEOUT=120

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=report_embeddings
CHROMA_EMBEDDING_MODEL=text-embedding-3-small

# Security
SECURITY_HEADERS_ENABLED=true
ENABLE_CSRF_PROTECTION=true

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.dicom

# Document Storage
DOCUMENT_STORAGE_DIR=./documents
DOCUMENT_MAX_SIZE_MB=20
DOCUMENT_ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Redis (optional, for production rate limiting)
REDIS_URL=

# Background Tasks
REMINDER_CHECK_INTERVAL_MINUTES=15

# Checkpoint Provider (in_memory | postgres)
CHECKPOINT_PROVIDER=in_memory

# AI Provider (vendor-agnostic)
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=text-embedding-004

# Appointment Management
APPOINTMENT_DURATION_MINUTES=30
APPOINTMENT_MIN_ADVANCE_HOURS=1
APPOINTMENT_MAX_DAYS_AHEAD=90
APPOINTMENT_CANCELLATION_WINDOW_HOURS=24
APPOINTMENT_REMINDER_HOURS_BEFORE=24,2
DEFAULT_TIMEZONE=UTC

# Observability — Logging
LOG_FORMAT=console

# Observability — Sentry (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=

# Observability — LangSmith (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-healthcare-dev
LANGSMITH_TRACING_SAMPLING_RATE=0.1

# Observability — OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ai-healthcare-backend
OTEL_TRACE_SAMPLING_RATE=0.1

# Observability — Prometheus
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# Backup
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE_CRON=0 3 * * *
