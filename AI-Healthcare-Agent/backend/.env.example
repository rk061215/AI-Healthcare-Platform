# ──────────────────────────────────────────────
# Backend Environment Variables
# ──────────────────────────────────────────────

# App
PROJECT_NAME=AI Healthcare Assistant API
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database
DATABASE_URL=postgresql://healthcare_user:healthcare_pass@localhost:5432/healthcare_agent
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_REFRESH_TOKEN_REMEMBER_ME_DAYS=30

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=2048

# Google Cloud Vision
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=report_embeddings
CHROMA_EMBEDDING_MODEL=text-embedding-3-small

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.dicom

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_LOGIN_PER_MINUTE=5

# Redis (optional, for production rate limiting)
REDIS_URL=

# Background Tasks
REMINDER_CHECK_INTERVAL_MINUTES=15
